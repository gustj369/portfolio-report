# ============================================================
# 로컬 개발 환경 — .env 파일로 복사해서 사용
# cp .env.example .env
# ============================================================

# Google Gemini API (무료 키 발급: https://aistudio.google.com/app/apikey)
# 없어도 동작 (fallback 분석기 사용)
GEMINI_API_KEY=

# FRED API (https://fred.stlouisfed.org/docs/api/api_key.html)
# 없어도 동작 (기본값 사용)
FRED_API_KEY=

# 토스페이먼츠 (현재 무료 플로우이므로 비워도 됨)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ============================================================
# 스토리지
# ============================================================

# Redis — 세션 데이터 영속성 (재시작해도 결제/리포트 상태 유지)
# 무료: https://upstash.com → Redis 생성 → REDIS_URL 복사
# 형식: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=

# Cloudflare R2 — PDF 파일 저장 (10GB 무료)
# 설정 없으면 로컬 폴더(generated_reports/)에 저장
# https://dash.cloudflare.com → R2 → 버킷 생성 → API 토큰
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=portfolio-reports        # 기본 권장 이름 — R2에서 생성한 버킷 이름과 일치시킬 것

# AWS S3 (R2 대신 사용할 경우)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2          # 서울 리전 기본값 — 다른 리전 사용 시 교체
S3_BUCKET=portfolio-reports        # 기본 권장 이름 — S3에서 생성한 버킷 이름과 일치시킬 것

# ============================================================
# 서버 설정
# ============================================================
USE_LOCAL_STORAGE=true        # true=로컬저장, false=R2/S3
FRONTEND_URL=http://localhost:3000  # 배포 시 Vercel URL로 교체 (예: https://your-app.vercel.app)
REPORT_PRICE_KRW=0                  # 0 = 무료 / 유료 전환 시 예: 4900

# ============================================================
# 이메일 발송 (선택 — 미설정 시 건너뜀)
# Gmail 앱 비밀번호: https://myaccount.google.com/apppasswords
# (2단계 인증 활성화 후 발급)
# ============================================================
SMTP_HOST=smtp.gmail.com           # Gmail 기본값 — 다른 메일 서비스 사용 시 교체
SMTP_PORT=587                      # STARTTLS 기본 포트 (SSL 사용 시 465로 변경)
SMTP_USER=                         # Gmail 주소 입력 (예: yourname@gmail.com)
SMTP_PASSWORD=                     # Gmail 앱 비밀번호 (일반 비밀번호 아님)
SMTP_FROM=                         # 미입력 시 SMTP_USER 값으로 자동 설정
